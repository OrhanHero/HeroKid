<UserControl x:Class="LernTor.App.Views.NewsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:LernTor.App.Localization"
             xmlns:controls="clr-namespace:LernTor.App.Controls">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="32,24">
            <TextBlock Style="{StaticResource HeadlineText}" Foreground="{StaticResource NewsBrush}">
                <Run Text="📰 " />
                <Run Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Stage_News], Mode=OneWay}" />
            </TextBlock>
            <TextBlock Style="{StaticResource SubtitleText}" Margin="0,8,0,0">
                <Run Text="{Binding DisplayIndex, Mode=OneWay}" />
                <Run Text=" / " />
                <Run Text="{Binding TotalArticles, Mode=OneWay}" />
            </TextBlock>
            <ProgressBar Style="{StaticResource ChildProgressBar}" Margin="0,12,0,0"
                         Minimum="0" Maximum="{Binding TotalArticles}" Value="{Binding DisplayIndex, Mode=OneWay}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" MaxWidth="820" Margin="32,0">
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20"
                        Visibility="{Binding CurrentArticle, Converter={StaticResource NullToVis}}">
                    <StackPanel>
                        <Image Source="{Binding CurrentArticle.ImageUrl}" MaxHeight="220" Stretch="Uniform"
                               Visibility="{Binding CurrentArticle.ImageUrl, Converter={StaticResource NullToVis}}"
                               Margin="0,0,0,16" />
                        <TextBlock Text="{Binding CurrentArticle.Title}" Style="{StaticResource HeadlineText}" FontSize="26" />
                        <TextBlock Text="{Binding CurrentArticle.SourceName}" Style="{StaticResource SubtitleText}" Margin="0,4,0,16" />
                        <TextBlock Text="{Binding CurrentArticle.SimplifiedSummary}" Style="{StaticResource BodyText}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[News_AnswerQuestions]}"
                           Style="{StaticResource SubtitleText}" FontWeight="Bold" Margin="0,0,0,12"
                           Visibility="{Binding CurrentArticle, Converter={StaticResource NullToVis}}" />

                <ItemsControl ItemsSource="{Binding CurrentQuestions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:QuestionCard Margin="0,0,0,16" HorizontalAlignment="Stretch" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,32">
            <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[News_NextArticle]}"
                    Style="{StaticResource RoundedButton}" FontSize="22" Padding="32,16"
                    IsEnabled="{Binding CanProceed}"
                    Visibility="{Binding IsLastArticle, Converter={StaticResource InverseBoolToVis}}"
                    Command="{Binding NextArticleCommand}" />
            <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[News_FinishSection]}"
                    Style="{StaticResource RoundedButton}" FontSize="22" Padding="32,16"
                    IsEnabled="{Binding CanProceed}"
                    Visibility="{Binding IsLastArticle, Converter={StaticResource BoolToVis}}"
                    Command="{Binding NextArticleCommand}" />
        </StackPanel>
    </Grid>
</UserControl>

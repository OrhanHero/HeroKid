<Window x:Class="LernTor.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LernTor.App.ViewModels"
        xmlns:views="clr-namespace:LernTor.App.Views"
        xmlns:loc="clr-namespace:LernTor.App.Localization"
        Title="LernTor"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ProfileSelectionViewModel}">
            <views:ProfileSelectionView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WelcomeViewModel}">
            <views:WelcomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReadingViewModel}">
            <views:ReadingView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WritingViewModel}">
            <views:WritingView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NewsViewModel}">
            <views:NewsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExerciseViewModel}">
            <views:ExerciseView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FinalQuizViewModel}">
            <views:FinalQuizView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ResultViewModel}">
            <views:ResultView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TypingDashboardViewModel}">
            <views:TypingDashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TypingExerciseViewModel}">
            <views:TypingExerciseView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TypingLessonCompleteViewModel}">
            <views:TypingLessonCompleteView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <ContentControl Content="{Binding CurrentViewModel}" />

        <!-- Datum/Uhrzeit (PC-Systemuhr), immer sichtbar, unauffällig -->
        <TextBlock Text="{Binding CurrentDateTimeDisplay}"
                   FontFamily="Segoe UI" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,12" Opacity="0.7" />

        <!-- Etappen der heutigen Session (Lesen → News → Fächer → Quiz), sichtbar sobald ein Profil
             gewählt ist - das Kind sieht jederzeit, wo es steht und was noch fehlt. -->
        <ItemsControl ItemsSource="{Binding SessionSteps}" HorizontalAlignment="Center" VerticalAlignment="Top"
                      Margin="0,10,0,0" IsHitTestVisible="False"
                      Visibility="{Binding ActiveProfileName, Converter={StaticResource EmptyStringToVis}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="14" Padding="12,5" Margin="3,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource CardBrush}" />
                                <Setter Property="Opacity" Value="0.75" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Opacity" Value="1" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDone}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
                                        <Setter Property="Opacity" Value="0.9" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓ " FontSize="13" FontWeight="Bold" Foreground="White"
                                       Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Aktives Profil, dauerhaft sichtbar sobald eins gewählt/erstellt wurde -->
        <TextBlock FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16,12" Opacity="0.85"
                   Visibility="{Binding ActiveProfileName, Converter={StaticResource EmptyStringToVis}}">
            <TextBlock.Text>
                <MultiBinding Converter="{StaticResource FormatWithArg}">
                    <Binding Source="{x:Static loc:LocalizationService.Instance}" Path="[Main_ActiveProfile]" />
                    <Binding Path="ActiveProfileName" Mode="OneWay" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <!-- Unauffälliger Eltern-Zugang, immer erreichbar, aber passwortgeschützt -->
        <Button x:Name="ParentAccessButton"
                Content="⚙"
                Width="40" Height="40"
                FontSize="18"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,12,12"
                Opacity="0.35"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Click="ParentAccessButton_Click"
                ToolTip="Eltern-Bereich" />
    </Grid>
</Window>

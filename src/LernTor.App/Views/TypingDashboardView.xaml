<UserControl x:Class="LernTor.App.Views.TypingDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:LernTor.App.Localization"
             xmlns:vm="clr-namespace:LernTor.App.ViewModels">
    <Grid Background="{StaticResource BackgroundBrush}" Style="{StaticResource FadeInOnLoad}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40">
            <StackPanel HorizontalAlignment="Center" MaxWidth="1000">
                <!-- Header -->
                <TextBlock Text="⌨️" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,12" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Typing_Title]}"
                           Style="{StaticResource HeadlineText}" FontSize="34" TextAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Typing_Instruction]}"
                           Style="{StaticResource SubtitleText}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,20" />

                <!-- Fortschrittsring + Statistiken -->
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,0,0,24">
                    <Grid Width="160" Height="160">
                        <Path Stroke="{StaticResource CardBrush}" StrokeThickness="16"
                              Data="M 80,80 m -60,0 a 60,60 0 1,1 120,0 a 60,60 0 1,1 -120,0" />
                        <Path x:Name="ProgressArc" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="16">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="80,20">
                                        <ArcSegment x:Name="ProgressSegment" Point="80,20" Size="60,60"
                                                    IsLargeArc="False" SweepDirection="Clockwise" />
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                        </Path>
                        <TextBlock Text="{Binding OverallProgress, StringFormat='{}{0:P0}'}"
                                   FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Typing_ProgressLabel]}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8" />
                    </Grid>

                    <StackPanel Orientation="Vertical" Margin="32,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{Binding CompletedCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                            <TextBlock Text=" / " FontSize="20" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="4,0" />
                            <TextBlock Text="{Binding TotalCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Typing_LessonsLabel]}" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="⭐ " FontSize="18" />
                            <TextBlock Text="{Binding EarnedStars}" FontSize="24" FontWeight="Bold" Foreground="#FFD700" />
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Typing_StarsLabel]}" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Lektions-Grid -->
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Typing_LessonsHeader]}"
                           Style="{StaticResource HeadlineText}" FontSize="24" TextAlignment="Center" Margin="0,0,0,16" />

                <ItemsControl ItemsSource="{Binding Lessons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" ItemWidth="300" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}" Margin="8" Width="280">
                                <StackPanel>
                                    <!-- Status-Header -->
                                    <Border Background="{StaticResource TileLavenderBrush}" CornerRadius="6,6,0,0" Padding="10,4" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Lesson.LessonType, Converter={StaticResource TypingLessonTypeToTitleConverter}}"
                                                   FontWeight="Bold" FontSize="12" Foreground="{StaticResource PrimaryBrush}" />
                                    </Border>

                                    <TextBlock Text="{Binding Title}" Style="{StaticResource HeadlineText}" FontSize="18"
                                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding Lesson.InstructionDe, Converter={StaticResource LocalizedInstructionConverter}}"
                                               Style="{StaticResource SubtitleText}" TextAlignment="Center" Margin="0,0,0,16" />

                                    <!-- Status -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <TextBlock Text="{Binding StatusIcon}" FontSize="20" />
                                        <TextBlock Text="{Binding StatusText}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{Binding IsCompleted, Converter={StaticResource BoolToSuccessBrushConverter}}" Margin="4,0,0,0" />
                                    </StackPanel>

                                    <!-- Stats -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                                        <Border Background="{StaticResource TileMintBrush}" CornerRadius="6" Padding="8,2" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding AccuracyDisplay}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryBrush}" />
                                                <TextBlock Text=" %" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="2,0,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{StaticResource TileLavenderBrush}" CornerRadius="6" Padding="8,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding WpmDisplay}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryBrush}" />
                                                <TextBlock Text=" WPM" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="2,0,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Sterne -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <ItemsControl ItemsSource="{Binding StarsList}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="⭐" FontSize="16" Margin="2,0" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Start-Button -->
                                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Typing_StartLesson]}"
                                            FontSize="18" Padding="24,10"
                                            HorizontalAlignment="Center" Margin="0,16,0,0"
                                            IsEnabled="{Binding IsUnlocked}"
                                            Command="{Binding DataContext.StartLessonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}"
                                            Visibility="{Binding IsUnlocked, Converter={StaticResource BoolToVis}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource RoundedButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                        <Setter Property="Content" Value="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Typing_LessonLocked]}"/>
                                                        <Setter Property="Background" Value="{StaticResource TextSecondaryBrush}" />
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Alle fertig -->
                <Border Style="{StaticResource CardBorder}" Margin="0,24,0,0" Visibility="{Binding HasCompletedAll, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="🎉" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Typing_AllCompleted]}"
                                   Style="{StaticResource HeadlineText}" FontSize="28" TextAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Typing_AllCompletedMsg]}"
                                   Style="{StaticResource BodyText}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,18" />
                        <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Typing_ContinueToNews]}"
                                Style="{StaticResource RoundedButton}" FontSize="18" Padding="24,10"
                                HorizontalAlignment="Center"
                                Command="{Binding ContinueToNewsCommand}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
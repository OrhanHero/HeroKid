<UserControl x:Class="LernTor.App.Views.ResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:LernTor.App.Localization">
    <Grid Background="{StaticResource BackgroundBrush}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="700">

            <TextBlock x:Name="CelebrationIcon" Text="🎉🏆🎉" FontSize="80" HorizontalAlignment="Center" Margin="0,0,0,20"
                       RenderTransformOrigin="0.5,0.5"
                       Visibility="{Binding Passed, Converter={StaticResource BoolToVis}}">
                <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="CelebrationScale" ScaleX="0.2" ScaleY="0.2" />
                </TextBlock.RenderTransform>
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CelebrationScale" Storyboard.TargetProperty="ScaleX"
                                                 To="1" Duration="0:0:0.5">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase EasingMode="EaseOut" Amplitude="0.6" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CelebrationScale" Storyboard.TargetProperty="ScaleY"
                                                 To="1" Duration="0:0:0.5">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase EasingMode="EaseOut" Amplitude="0.6" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>

            <TextBlock Text="💪" FontSize="80" HorizontalAlignment="Center" Margin="0,0,0,20"
                       Visibility="{Binding Passed, Converter={StaticResource InverseBoolToVis}}" />

            <TextBlock Style="{StaticResource HeadlineText}" FontSize="38" TextAlignment="Center" HorizontalAlignment="Center"
                       Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Result_PassedTitle]}"
                       Visibility="{Binding Passed, Converter={StaticResource BoolToVis}}" />
            <TextBlock Style="{StaticResource HeadlineText}" FontSize="38" TextAlignment="Center" HorizontalAlignment="Center"
                       Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Result_FailedTitle]}"
                       Visibility="{Binding Passed, Converter={StaticResource InverseBoolToVis}}" />

            <TextBlock Style="{StaticResource SubtitleText}" TextAlignment="Center" Margin="0,16,0,8"
                       Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Result_PassedText]}"
                       Visibility="{Binding Passed, Converter={StaticResource BoolToVis}}" />
            <TextBlock Style="{StaticResource SubtitleText}" TextAlignment="Center" Margin="0,16,0,8"
                       Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Result_FailedText]}"
                       Visibility="{Binding Passed, Converter={StaticResource InverseBoolToVis}}" />

            <TextBlock Style="{StaticResource BodyText}" TextAlignment="Center" Margin="0,8,0,32" FontWeight="Bold"
                       Visibility="{Binding Result, Converter={StaticResource NullToVis}}">
                <Run Text="{Binding CorrectCount, Mode=OneWay}" />
                <Run Text=" / " />
                <Run Text="{Binding TotalQuestions, Mode=OneWay}" />
            </TextBlock>

            <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Result_UnlockButton]}"
                    Style="{StaticResource RoundedButton}" FontSize="24" Padding="36,16" HorizontalAlignment="Center"
                    Visibility="{Binding Passed, Converter={StaticResource BoolToVis}}"
                    Command="{Binding ConfirmUnlockCommand}" />

            <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Result_RetryButton]}"
                    Style="{StaticResource RoundedButton}" FontSize="24" Padding="36,16" HorizontalAlignment="Center"
                    Visibility="{Binding Passed, Converter={StaticResource InverseBoolToVis}}"
                    Command="{Binding RetryWeakSubjectsCommand}" />
        </StackPanel>
    </Grid>
</UserControl>

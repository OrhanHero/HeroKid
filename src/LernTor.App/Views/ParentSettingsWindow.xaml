<Window x:Class="LernTor.App.Views.ParentSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:LernTor.App.Localization"
        Title="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_LoginTitle]}"
        Width="760" Height="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <!-- Gemeinsame Berichts-Zeile (Label + Ampel-Balken + Quote): genutzt vom Fach-Bericht
             UND der Themen-Heatmap ("Schwächste Themen"), damit beide identisch aussehen. -->
        <DataTemplate x:Key="ReportRowTemplate">
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="13" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" ToolTip="{Binding Label}" />
                <ProgressBar Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Rate, Mode=OneWay}"
                             Height="14" BorderThickness="0" Background="{StaticResource ProgressTrackBrush}">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStrong}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsWeak}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
                <TextBlock Grid.Column="2" Text="{Binding RateDisplay}" FontSize="12"
                           VerticalAlignment="Center" Margin="10,0,0,0" />
            </Grid>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="28">

        <!-- Login / Ersteinrichtung -->
        <StackPanel VerticalAlignment="Center" MaxWidth="420"
                    Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVis}}">
            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_LoginTitle]}"
                       Style="{StaticResource HeadlineText}" FontSize="28" Margin="0,0,0,20" />
            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_SetupPasswordPrompt]}"
                       Style="{StaticResource BodyText}" Margin="0,0,0,8"
                       Visibility="{Binding IsFirstTimeSetup, Converter={StaticResource BoolToVis}}" />
            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_PasswordPrompt]}"
                       Style="{StaticResource BodyText}" Margin="0,0,0,8"
                       Visibility="{Binding IsFirstTimeSetup, Converter={StaticResource InverseBoolToVis}}" />
            <PasswordBox x:Name="PasswordInput" FontSize="18" Padding="10" KeyDown="PasswordInput_KeyDown" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Login]}"
                        Style="{StaticResource RoundedButton}" Margin="0,0,12,0" HorizontalAlignment="Left"
                        Click="LoginButton_Click" />
                <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_UnlockAndExit]}"
                        Style="{StaticResource RoundedButton}" Background="{StaticResource ErrorBrush}" HorizontalAlignment="Left"
                        Click="UnlockAndExitButton_Click" />
            </StackPanel>
        </StackPanel>

        <!-- Eltern-Einstellungen -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_DisabledSubjects]}"
                           Style="{StaticResource SubtitleText}" FontWeight="Bold" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding SubjectToggles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsDisabled}"
                                      Margin="0,4,24,4" FontSize="16" MinWidth="200" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_ActivityLogFor]}"
                           Style="{StaticResource SubtitleText}" FontWeight="Bold" Margin="0,20,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="Name" Width="240" FontSize="16" Padding="8" Margin="0,0,12,0" />
                    <!-- Löscht das gewählte Profil (mit Rückfrage; das letzte Profil bleibt geschützt). -->
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_DeleteProfile]}"
                            Style="{StaticResource RoundedButton}" Background="{StaticResource ErrorBrush}"
                            FontSize="14" Padding="14,8"
                            Command="{Binding DeleteSelectedProfileCommand}" />
                </StackPanel>

                <!-- Schwierigkeitsstufen (pro oben gewähltem Profil) - vorkonfigurierte Presets statt
                     freier Eingabe, damit Eltern keinen ungültigen Wert setzen können und kein neuer
                     Build nötig ist, um die Hürden zu verändern. -->
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Difficulty_Title]}"
                           Style="{StaticResource SubtitleText}" FontWeight="Bold" Margin="0,20,0,8" />

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Difficulty_Typing]}"
                           Style="{StaticResource BodyText}" FontSize="14" Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="25%" Style="{StaticResource TabPillButton}" Command="{Binding SetTypingMinAccuracyCommand}" CommandParameter="25">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="25" />
                                <Binding Path="TypingMinAccuracyPercent" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="50%" Style="{StaticResource TabPillButton}" Command="{Binding SetTypingMinAccuracyCommand}" CommandParameter="50">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="50" />
                                <Binding Path="TypingMinAccuracyPercent" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="75%" Style="{StaticResource TabPillButton}" Command="{Binding SetTypingMinAccuracyCommand}" CommandParameter="75">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="75" />
                                <Binding Path="TypingMinAccuracyPercent" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="85%" Style="{StaticResource TabPillButton}" Command="{Binding SetTypingMinAccuracyCommand}" CommandParameter="85">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="85" />
                                <Binding Path="TypingMinAccuracyPercent" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                </StackPanel>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Difficulty_QuizFirst]}"
                           Style="{StaticResource BodyText}" FontSize="14" Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="50%" Style="{StaticResource TabPillButton}" Command="{Binding SetQuizFirstAttemptThresholdCommand}" CommandParameter="50">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="50" />
                                <Binding Path="QuizFirstAttemptThresholdPercent" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="75%" Style="{StaticResource TabPillButton}" Command="{Binding SetQuizFirstAttemptThresholdCommand}" CommandParameter="75">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="75" />
                                <Binding Path="QuizFirstAttemptThresholdPercent" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="85%" Style="{StaticResource TabPillButton}" Command="{Binding SetQuizFirstAttemptThresholdCommand}" CommandParameter="85">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="85" />
                                <Binding Path="QuizFirstAttemptThresholdPercent" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                </StackPanel>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Difficulty_QuizRetry]}"
                           Style="{StaticResource BodyText}" FontSize="14" Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="25%" Style="{StaticResource TabPillButton}" Command="{Binding SetQuizRetryThresholdCommand}" CommandParameter="25">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="25" />
                                <Binding Path="QuizRetryThresholdPercent" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="50%" Style="{StaticResource TabPillButton}" Command="{Binding SetQuizRetryThresholdCommand}" CommandParameter="50">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="50" />
                                <Binding Path="QuizRetryThresholdPercent" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                </StackPanel>

                <!-- 🔥-Lernserie: reine Anzeige-Motivation, Standard aus (bewusst kein
                     Streak-Druck bei verpassten Tagen - keine Strafen, keine Erinnerungen). -->
                <CheckBox IsChecked="{Binding StreaksEnabled}" Margin="0,4,0,16" FontSize="14"
                          Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Streaks_Toggle]}" />

                <ListView ItemsSource="{Binding RecentActivity}" MaxHeight="220" FontSize="13">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Zeit" DisplayMemberBinding="{Binding Timestamp}" Width="140" />
                            <GridViewColumn Header="Fach" DisplayMemberBinding="{Binding Subject}" Width="90" />
                            <GridViewColumn Header="Thema" DisplayMemberBinding="{Binding Topic}" Width="160" />
                            <GridViewColumn Header="Richtig?" DisplayMemberBinding="{Binding WasCorrect}" Width="70" />
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Wochen-/Monatsbericht: Stärken/Schwächen je Fach (schwächste zuerst), Lerntage,
                     Quiz-Verlauf - für das oben gewählte Profil. -->
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Report_Title]}"
                           Style="{StaticResource SubtitleText}" FontWeight="Bold" Margin="0,24,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Report_Days7]}"
                            Style="{StaticResource TabPillButton}" Command="{Binding SetReportPeriodCommand}" CommandParameter="7">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="7" />
                                <Binding Path="ReportDays" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Report_Days30]}"
                            Style="{StaticResource TabPillButton}" Command="{Binding SetReportPeriodCommand}" CommandParameter="30">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="30" />
                                <Binding Path="ReportDays" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                </StackPanel>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Report_NoData]}"
                           Style="{StaticResource BodyText}" Opacity="0.7"
                           Visibility="{Binding HasReportData, Converter={StaticResource InverseBoolToVis}}" />

                <StackPanel Visibility="{Binding HasReportData, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding ReportRows}" ItemTemplate="{StaticResource ReportRowTemplate}" />

                    <!-- Themen-Heatmap: die schwächsten EINZEL-Themen (nicht nur Fächer) - damit
                         Eltern sehen, dass z.B. genau "Brüche" hakt und nicht pauschal "Mathe". -->
                    <StackPanel Visibility="{Binding HasTopicReportData, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Report_WeakTopics]}"
                                   Style="{StaticResource BodyText}" FontWeight="Bold" FontSize="14" Margin="0,14,0,4" />
                        <ItemsControl ItemsSource="{Binding TopicReportRows}" ItemTemplate="{StaticResource ReportRowTemplate}" />
                    </StackPanel>

                    <TextBlock Text="{Binding ReportLearnedDaysDisplay}" Style="{StaticResource BodyText}" FontSize="14" Margin="0,10,0,0" />
                    <TextBlock Text="{Binding ReportQuizTrendDisplay}" Style="{StaticResource BodyText}" FontSize="14" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Save]}"
                            Style="{StaticResource RoundedButton}" Margin="0,0,12,0" Command="{Binding SaveCommand}" />
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Close]}"
                            Style="{StaticResource RoundedButton}" Background="{StaticResource TextSecondaryBrush}"
                            Margin="0,0,12,0" Command="{Binding CloseCommand}" />
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_SkipUnlock]}"
                            Style="{StaticResource RoundedButton}" Background="{StaticResource ErrorBrush}"
                            Command="{Binding SkipUnlockCommand}" />
                </StackPanel>

                <!-- Eigene Aufgaben (z.B. aktuelle Hausaufgaben der Lehrkraft) -->
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Title]}"
                           Style="{StaticResource SubtitleText}" FontWeight="Bold" Margin="0,32,0,4" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Intro]}"
                           Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,12" />

                <UniformGrid Columns="3" Margin="0,0,0,10">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Subject]}" FontSize="13" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableSubjects}" SelectedItem="{Binding NewQuestionSubject}" Padding="6">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource SubjectToTitle}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Grade]}" FontSize="13" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableGradeLevels}" SelectedItem="{Binding NewQuestionGrade}" Padding="6" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Type]}" FontSize="13" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableQuestionTypes}" SelectedItem="{Binding NewQuestionType}" Padding="6" />
                    </StackPanel>
                </UniformGrid>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Topic]}" FontSize="13" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewQuestionTopic, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Prompt]}" FontSize="13" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewQuestionPrompt, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10"
                         AcceptsReturn="True" TextWrapping="Wrap" MinLines="2" MaxLines="4" />

                <StackPanel Visibility="{Binding NewQuestionNeedsOptions, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Options]}" FontSize="13" Margin="0,0,0,4" />
                    <TextBox Text="{Binding NewQuestionOptionsText, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />
                </StackPanel>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_CorrectAnswers]}" FontSize="13" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewQuestionCorrectAnswersText, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Explanation]}" FontSize="13" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewQuestionExplanation, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10"
                         AcceptsReturn="True" TextWrapping="Wrap" MinLines="2" MaxLines="4" />

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_HelpHint]}" FontSize="13" Margin="0,0,0,4" />
                <TextBox Text="{Binding NewQuestionHelpHint, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                <TextBlock Text="{Binding CustomQuestionErrorMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />

                <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Add]}"
                        Style="{StaticResource RoundedButton}" HorizontalAlignment="Left" Margin="0,0,0,20"
                        Command="{Binding AddCustomQuestionCommand}" />

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_ExistingTitle]}"
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Empty]}"
                           Style="{StaticResource BodyText}" Margin="0,0,0,20"
                           Visibility="{Binding HasNoCustomQuestions, Converter={StaticResource BoolToVis}}" />
                <ItemsControl ItemsSource="{Binding CustomQuestions}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontWeight="Bold" FontSize="13">
                                            <Run Text="{Binding Subject, Converter={StaticResource SubjectToTitle}, Mode=OneWay}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding GradeLevel, Mode=OneWay}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding Topic, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding Prompt}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Delete]}"
                                            Style="{StaticResource OptionButton}" VerticalAlignment="Top"
                                            Command="{Binding DataContext.DeleteCustomQuestionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Automatisches Einlesen von Lehrer-Unterlagen + KI-Lernchat (lokales LLM, siehe README) -->
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_Title]}"
                           Style="{StaticResource SubtitleText}" FontWeight="Bold" Margin="0,32,0,4" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_Intro]}"
                           Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,12" />

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_ModelChoice]}" FontSize="13" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding AvailableLlmModels}" SelectedItem="{Binding SelectedLlmModel}"
                          DisplayMemberPath="DisplayName" Padding="6" Margin="0,0,0,16" MaxWidth="520" HorizontalAlignment="Left" />

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_LocalModelPath]}" FontSize="13" Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_PickModelFile]}"
                            Style="{StaticResource RoundedButton}" Margin="0,0,12,0" Command="{Binding PickLocalLlmModelFileCommand}" />
                    <Button Content="✕" Style="{StaticResource RoundedButton}" Background="{StaticResource TextSecondaryBrush}"
                            Padding="12,8" Margin="0,0,12,0" Command="{Binding ClearLocalLlmModelFileCommand}"
                            Visibility="{Binding LocalLlmModelPath, Converter={StaticResource EmptyStringToVis}}"
                            ToolTip="Eigene Modelldatei entfernen" />
                    <TextBlock Text="{Binding LocalLlmModelPath}" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="400">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LocalLlmModelPath}" Value="">
                                        <Setter Property="Text" Value="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_NoFile]}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <UniformGrid Columns="2" Margin="0,0,0,10">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Subject]}" FontSize="13" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableSubjects}" SelectedItem="{Binding ImportSubject}" Padding="6">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource SubjectToTitle}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Grade]}" FontSize="13" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableGradeLevels}" SelectedItem="{Binding ImportGrade}" Padding="6" />
                    </StackPanel>
                </UniformGrid>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_PickFile]}"
                            Style="{StaticResource RoundedButton}" Margin="0,0,12,0" Command="{Binding PickImportFileCommand}" />
                    <TextBlock Text="{Binding ImportFilePath}" VerticalAlignment="Center" TextWrapping="Wrap"
                               MaxWidth="400">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ImportFilePath}" Value="">
                                        <Setter Property="Text" Value="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_NoFile]}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_Run]}"
                        Style="{StaticResource RoundedButton}" HorizontalAlignment="Left" Margin="0,0,0,8"
                        Command="{Binding RunImportCommand}" IsEnabled="{Binding IsImporting, Converter={StaticResource InverseBool}}" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_Running]}"
                           Style="{StaticResource BodyText}" Margin="0,0,0,8"
                           Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding ImportErrorMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_ResultsTitle]}"
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,8"
                           Visibility="{Binding HasNoImportedDrafts, Converter={StaticResource InverseBoolToVis}}" />
                <!-- Vorschlagskarten mit Inline-Editing: alle Felder direkt korrigierbar, erst
                     "Übernehmen" validiert und speichert. Die Belegstelle aus dem Dokument bleibt
                     bewusst nicht editierbar (sie ist die Prüf-Referenz, kein Inhalt). -->
                <ItemsControl ItemsSource="{Binding ImportedDrafts}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_FieldTopic]}" FontSize="11" Opacity="0.7" />
                                        <TextBox Text="{Binding Topic, UpdateSourceTrigger=PropertyChanged}" FontSize="13" FontWeight="Bold" Padding="4" Margin="0,2,0,6" />

                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_FieldPrompt]}" FontSize="11" Opacity="0.7" />
                                        <TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" Padding="4" Margin="0,2,0,6" />

                                        <StackPanel Visibility="{Binding NeedsOptions, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_FieldOptions]}" FontSize="11" Opacity="0.7" />
                                            <TextBox Text="{Binding OptionsText, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" FontSize="12" Padding="4" Margin="0,2,0,6" />
                                        </StackPanel>

                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_FieldCorrectAnswers]}" FontSize="11" Opacity="0.7" />
                                        <TextBox Text="{Binding CorrectAnswersText, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Padding="4" Margin="0,2,0,6" />

                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_FieldExplanation]}" FontSize="11" Opacity="0.7" />
                                        <TextBox Text="{Binding Explanation, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" FontSize="12" Padding="4" Margin="0,2,0,6" />

                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_FieldHelpHint]}" FontSize="11" Opacity="0.7" />
                                        <TextBox Text="{Binding HelpHint, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Padding="4" Margin="0,2,0,6" />

                                        <TextBlock Text="{Binding ValidationError}" Foreground="{StaticResource ErrorBrush}"
                                                   FontSize="12" TextWrapping="Wrap" Margin="0,2,0,4"
                                                   Visibility="{Binding ValidationError, Converter={StaticResource EmptyStringToVis}}" />

                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_SourceExcerpt]}"
                                                   FontSize="11" FontWeight="Bold" Opacity="0.7" Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding SourceExcerpt}" TextWrapping="Wrap" FontSize="11" Opacity="0.7" FontStyle="Italic" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                        <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_Accept]}"
                                                Style="{StaticResource OptionButton}" Margin="0,0,0,4"
                                                Command="{Binding DataContext.AcceptImportedDraftCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Import_Discard]}"
                                                Style="{StaticResource OptionButton}"
                                                Command="{Binding DataContext.DiscardImportedDraftCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Natürliche Vorlesestimmen (Piper, siehe PiperTtsEngine): einmaliger Download,
                     danach liest der Lesen-Abschnitt mit neuronalen Offline-Stimmen für DE/TR/EN
                     vor statt mit der roboterhaften Windows-SAPI-Stimme. -->
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Tts_Title]}"
                           Style="{StaticResource SubtitleText}" FontWeight="Bold" Margin="0,32,0,4" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Tts_Intro]}"
                           Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Tts_Install]}"
                            Style="{StaticResource RoundedButton}" Margin="0,0,12,0"
                            Command="{Binding InstallPiperVoicesCommand}"
                            IsEnabled="{Binding IsPiperInstalling, Converter={StaticResource InverseBool}}"
                            Visibility="{Binding IsPiperInstalled, Converter={StaticResource InverseBoolToVis}}" />
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Tts_Installed]}"
                               Style="{StaticResource BodyText}" FontWeight="Bold" VerticalAlignment="Center"
                               Foreground="{StaticResource SuccessBrush}"
                               Visibility="{Binding IsPiperInstalled, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
                <TextBlock Text="{Binding PiperStatusMessage}" Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,8"
                           Visibility="{Binding PiperStatusMessage, Converter={StaticResource EmptyStringToVis}}" />
                <TextBlock Text="{Binding PiperErrorMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,0,0,20"
                           Visibility="{Binding PiperErrorMessage, Converter={StaticResource EmptyStringToVis}}" />

                <!-- 🎁 Belohnungen: Eltern legen fest, was Kinder mit ihren Sternen einlösen können;
                     Einlösungen erscheinen unten je gewähltem Profil (oben beim Aktivitätsprotokoll). -->
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Rewards_Title]}"
                           Style="{StaticResource SubtitleText}" FontWeight="Bold" Margin="0,32,0,4" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Rewards_Intro]}"
                           Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox Text="{Binding NewRewardEmoji, UpdateSourceTrigger=PropertyChanged}" Width="60"
                             ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Rewards_EmojiHint]}"
                             Margin="0,0,8,0" />
                    <TextBox Text="{Binding NewRewardTitle, UpdateSourceTrigger=PropertyChanged}" Width="320"
                             ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Rewards_TitleHint]}"
                             Margin="0,0,8,0" />
                    <TextBox Text="{Binding NewRewardCostText, UpdateSourceTrigger=PropertyChanged}" Width="70"
                             ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Rewards_CostHint]}"
                             Margin="0,0,8,0" />
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Rewards_Add]}"
                            Style="{StaticResource RoundedButton}" FontSize="14" Padding="14,8"
                            Command="{Binding AddRewardCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding RewardErrorMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,0,0,8"
                           Visibility="{Binding RewardErrorMessage, Converter={StaticResource EmptyStringToVis}}" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Rewards_Empty]}"
                           Style="{StaticResource BodyText}" Margin="0,0,0,12"
                           Visibility="{Binding HasNoRewards, Converter={StaticResource BoolToVis}}" />
                <ItemsControl ItemsSource="{Binding Rewards}" Margin="0,0,0,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock FontSize="14" VerticalAlignment="Center" MinWidth="360">
                                    <Run Text="{Binding Emoji, Mode=OneWay}" />
                                    <Run Text="{Binding Title, Mode=OneWay}" />
                                    <Run Text=" – " />
                                    <Run Text="{Binding StarCost, Mode=OneWay}" FontWeight="Bold" />
                                    <Run Text=" ⭐" />
                                </TextBlock>
                                <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_CustomQuestions_Delete]}"
                                        Style="{StaticResource OptionButton}" Margin="12,0,0,0"
                                        Command="{Binding DataContext.DeleteRewardCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Rewards_RedemptionsTitle]}"
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,6" />
                <ItemsControl ItemsSource="{Binding RewardRedemptions}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="13" Margin="0,2">
                                <Run Text="{Binding RedeemedAt, Mode=OneWay, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Foreground="Gray" />
                                <Run Text="  " />
                                <Run Text="{Binding RewardEmoji, Mode=OneWay}" />
                                <Run Text="{Binding RewardTitle, Mode=OneWay}" />
                                <Run Text=" (" /><Run Text="{Binding StarCost, Mode=OneWay}" /><Run Text=" ⭐)" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Fehlerprotokoll: lokale Log-Dateien (AppLog), z.B. übersprungene News-Feeds,
                     Download-Fehler, Abstürze - komplett lokal, keine Telemetrie. -->
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Log_Title]}"
                           Style="{StaticResource SubtitleText}" FontWeight="Bold" Margin="0,32,0,4" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Log_Intro]}"
                           Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Log_OpenFolder]}"
                            Style="{StaticResource RoundedButton}" FontSize="14" Padding="14,8" Margin="0,0,12,0"
                            Command="{Binding OpenLogFolderCommand}" />
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Log_Refresh]}"
                            Style="{StaticResource RoundedButton}" FontSize="14" Padding="14,8"
                            Background="{StaticResource TextSecondaryBrush}"
                            Command="{Binding RefreshErrorLogCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Log_Empty]}"
                           Style="{StaticResource BodyText}" Margin="0,0,0,20"
                           Visibility="{Binding HasErrorLogEntries, Converter={StaticResource InverseBoolToVis}}" />
                <TextBox Text="{Binding ErrorLogTail, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                         TextWrapping="NoWrap" AcceptsReturn="True" MaxHeight="220" Margin="0,0,0,20"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         Visibility="{Binding HasErrorLogEntries, Converter={StaticResource BoolToVis}}" />

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Backup_Title]}"
                           Style="{StaticResource SubtitleText}" FontWeight="Bold" Margin="0,12,0,8" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Backup_Intro]}"
                           Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Backup_Export]}"
                            Style="{StaticResource RoundedButton}" FontSize="14" Padding="14,8" Margin="0,0,12,0"
                            Command="{Binding ExportBackupCommand}" />
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_Backup_Import]}"
                            Style="{StaticResource RoundedButton}" FontSize="14" Padding="14,8"
                            Background="{StaticResource TextSecondaryBrush}"
                            Command="{Binding ImportBackupCommand}" />
                </StackPanel>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_DangerZone]}"
                           Style="{StaticResource SubtitleText}" FontWeight="Bold" Margin="0,12,0,8"
                           Foreground="{StaticResource ErrorBrush}" />
                <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Parent_ResetAllData]}"
                        Style="{StaticResource RoundedButton}" Background="{StaticResource ErrorBrush}"
                        HorizontalAlignment="Left" Command="{Binding ResetAllDataCommand}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

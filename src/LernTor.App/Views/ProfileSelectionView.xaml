<UserControl x:Class="LernTor.App.Views.ProfileSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:LernTor.App.Localization"
             xmlns:controls="clr-namespace:LernTor.App.Controls">
    <Grid Background="{StaticResource BackgroundBrush}" Style="{StaticResource FadeInOnLoad}">

        <!-- Profil-Dashboard -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="960"
                    Visibility="{Binding IsCreatingNewProfile, Converter={StaticResource InverseBoolToVis}}">
            <TextBlock Text="{Binding Greeting}" FontSize="26" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center"
                       HorizontalAlignment="Center" Margin="0,0,0,4" />
            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Profile_Title]}"
                       Style="{StaticResource HeadlineText}" FontSize="36" TextAlignment="Center"
                       HorizontalAlignment="Center" Margin="0,0,0,36" />

            <ItemsControl ItemsSource="{Binding ProfileTiles}" AlternationCount="4">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Margin="12" Padding="28,24" Width="240"
                                Command="{Binding DataContext.SelectProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <Button.Style>
                                <!-- Pastell-Hintergrund rotiert über die Kacheln (AlternationIndex liegt
                                     auf dem ContentPresenter, dem Container des Templates). -->
                                <Style TargetType="Button" BasedOn="{StaticResource ProfileTileButton}">
                                    <Setter Property="Background" Value="{StaticResource TileLavenderBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}}" Value="1">
                                            <Setter Property="Background" Value="{StaticResource TileSandBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}}" Value="2">
                                            <Setter Property="Background" Value="{StaticResource TileMintBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}}" Value="3">
                                            <Setter Property="Background" Value="{StaticResource TileRoseBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel HorizontalAlignment="Center">
                                <!-- Avatar im Fortschrittsring: der Ring zeigt, wie weit die heutige
                                     Session ist (grün + Häkchen, wenn schon freigeschaltet). -->
                                <Grid Width="104" Height="104" Margin="0,0,0,12">
                                    <controls:ProgressArc Fraction="{Binding ProgressFraction}"
                                                          StrokeThickness="7"
                                                          TrackBrush="{StaticResource ProgressTrackBrush}">
                                        <controls:ProgressArc.Style>
                                            <Style TargetType="controls:ProgressArc">
                                                <Setter Property="Stroke" Value="{StaticResource PrimaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDoneToday}" Value="True">
                                                        <Setter Property="Stroke" Value="{StaticResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </controls:ProgressArc.Style>
                                    </controls:ProgressArc>
                                    <TextBlock Text="{Binding AvatarEmoji}" FontSize="48"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <TextBlock Text="✅" FontSize="22" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                               Visibility="{Binding IsDoneToday, Converter={StaticResource BoolToVis}}" />
                                </Grid>
                                <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}" FontWeight="Bold"
                                           FontSize="21" TextAlignment="Center" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Profile, Converter={StaticResource ProfileToSubtitle}}"
                                           Style="{StaticResource SubtitleText}" FontSize="14" TextAlignment="Center" />
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Profile_DoneToday]}"
                                           FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"
                                           TextAlignment="Center" Margin="0,6,0,0"
                                           Visibility="{Binding IsDoneToday, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Profile_NewProfile]}"
                    Style="{StaticResource RoundedButton}" FontSize="18" Padding="24,14"
                    HorizontalAlignment="Center" Margin="0,32,0,0"
                    Command="{Binding ShowCreateFormCommand}" />
        </StackPanel>

        <!-- Neues Profil erstellen -->
        <Border Style="{StaticResource CardBorder}" MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center"
                Visibility="{Binding IsCreatingNewProfile, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Profile_NewProfile]}"
                           Style="{StaticResource HeadlineText}" FontSize="26" Margin="0,0,0,20" />

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Profile_AvatarLabel]}" Style="{StaticResource BodyText}" Margin="0,0,0,4" />
                <ItemsControl ItemsSource="{Binding AvatarChoices}" Margin="0,0,0,16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Style="{StaticResource AvatarPickButton}"
                                    Command="{Binding DataContext.PickAvatarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Tag>
                                    <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                        <Binding />
                                        <Binding Path="DataContext.SelectedAvatar" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                    </MultiBinding>
                                </Button.Tag>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Profile_NameLabel]}" Style="{StaticResource BodyText}" />
                <TextBox Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}" FontSize="18" Padding="10" Margin="0,4,0,16">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding CreateProfileCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Profile_AgeLabel]}" Style="{StaticResource BodyText}" />
                <TextBox Text="{Binding NewProfileAge, UpdateSourceTrigger=PropertyChanged}" FontSize="18" Padding="10" Margin="0,4,0,16" Width="100" HorizontalAlignment="Left">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding CreateProfileCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Profile_ClassLabel]}" Style="{StaticResource BodyText}" />
                <TextBox Text="{Binding NewProfileClassLabel, UpdateSourceTrigger=PropertyChanged}" FontSize="18" Padding="10" Margin="0,4,0,16" Width="140" HorizontalAlignment="Left">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding CreateProfileCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Profile_GradeLevelLabel]}" Style="{StaticResource BodyText}" Margin="0,0,0,4" />
                <RadioButton Content="Klasse 6" IsChecked="{Binding NewProfileIsGrade9, Converter={StaticResource InverseBool}}" FontSize="16" Margin="0,4" />
                <RadioButton Content="Klasse 9" IsChecked="{Binding NewProfileIsGrade9}" FontSize="16" Margin="0,4,0,16" />

                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Profile_CreateButton]}"
                            Style="{StaticResource RoundedButton}" Margin="0,0,12,0" Command="{Binding CreateProfileCommand}" />
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Profile_CancelButton]}"
                            Style="{StaticResource RoundedButton}" Background="{StaticResource TextSecondaryBrush}"
                            Command="{Binding CancelCreateFormCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

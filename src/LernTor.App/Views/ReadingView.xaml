<UserControl x:Class="LernTor.App.Views.ReadingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:LernTor.App.Localization">
    <Grid Background="{StaticResource BackgroundBrush}" Style="{StaticResource FadeInOnLoad}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40">
            <StackPanel HorizontalAlignment="Center" MaxWidth="1400">
                <TextBlock Text="📖" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,12" />

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Reading_Title]}"
                           Style="{StaticResource HeadlineText}" FontSize="34" TextAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Reading_Instruction]}"
                           Style="{StaticResource SubtitleText}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,20" />

                <!-- Sprach-Tabs + Vorlesen: "Alle" = die bewusst beibehaltene Drei-Spalten-Ansicht,
                     einzelne Sprachen größer/luftiger für besseres (Vor-)Lesen. -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Reading_TabAll]}"
                            Style="{StaticResource TabPillButton}"
                            Command="{Binding SelectTabCommand}" CommandParameter="All">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="All" />
                                <Binding Path="SelectedTab" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="Deutsch" Style="{StaticResource TabPillButton}"
                            Command="{Binding SelectTabCommand}" CommandParameter="De">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="De" />
                                <Binding Path="SelectedTab" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="Türkçe" Style="{StaticResource TabPillButton}"
                            Command="{Binding SelectTabCommand}" CommandParameter="Tr">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="Tr" />
                                <Binding Path="SelectedTab" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="English" Style="{StaticResource TabPillButton}"
                            Command="{Binding SelectTabCommand}" CommandParameter="En">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualsToSelectedTag}">
                                <Binding Source="En" />
                                <Binding Path="SelectedTab" />
                            </MultiBinding>
                        </Button.Tag>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource TextSecondaryBrush}" Opacity="0.25" Margin="12,4" />

                    <!-- Vorlesen (Windows-TTS, offline): liest die gewählte Sprache, im "Alle"-Modus Deutsch -->
                    <Button Style="{StaticResource TabPillButton}" Command="{Binding ToggleReadAloudCommand}">
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Reading_ReadAloud], Mode=OneWay}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                            <Setter Property="Text" Value="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Reading_StopReading], Mode=OneWay}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </StackPanel>

                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="{Binding Piece.Title}" Style="{StaticResource HeadlineText}" FontSize="24"
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding Piece.Author}" Style="{StaticResource BodyText}" FontStyle="Italic"
                                   TextAlignment="Center" Margin="0,0,0,20" />

                        <!-- Drei Sprachfenster nebeneinander: dieselbe Übertragung auf Deutsch/Türkisch/Englisch -->
                        <Grid Visibility="{Binding IsAllTab, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="6" Padding="10,4"
                                        HorizontalAlignment="Center" Margin="0,0,0,12">
                                    <TextBlock Text="Deutsch" FontWeight="Bold" />
                                </Border>
                                <TextBlock Text="{Binding Piece.TextDe}" Style="{StaticResource BodyText}" FontSize="18"
                                           TextWrapping="Wrap" LineHeight="28" />
                            </StackPanel>

                            <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource TextSecondaryBrush}" Opacity="0.25" Margin="20,0" />

                            <StackPanel Grid.Column="2">
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="6" Padding="10,4"
                                        HorizontalAlignment="Center" Margin="0,0,0,12">
                                    <TextBlock Text="Türkçe" FontWeight="Bold" />
                                </Border>
                                <TextBlock Text="{Binding Piece.TextTr}" Style="{StaticResource BodyText}" FontSize="18"
                                           TextWrapping="Wrap" LineHeight="28" />
                            </StackPanel>

                            <Rectangle Grid.Column="3" Width="1" Fill="{StaticResource TextSecondaryBrush}" Opacity="0.25" Margin="20,0" />

                            <StackPanel Grid.Column="4">
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="6" Padding="10,4"
                                        HorizontalAlignment="Center" Margin="0,0,0,12">
                                    <TextBlock Text="English" FontWeight="Bold" />
                                </Border>
                                <TextBlock Text="{Binding Piece.TextEn}" Style="{StaticResource BodyText}" FontSize="18"
                                           TextWrapping="Wrap" LineHeight="28" />
                            </StackPanel>
                        </Grid>

                        <!-- Einzelsprache: größere Schrift + mehr Zeilenabstand für angenehmes (Vor-)Lesen -->
                        <TextBlock Text="{Binding SingleTabText}" Style="{StaticResource BodyText}"
                                   FontSize="22" LineHeight="38" TextWrapping="Wrap"
                                   MaxWidth="820" HorizontalAlignment="Center"
                                   Visibility="{Binding IsSingleTab, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>

                <StackPanel HorizontalAlignment="Center" Margin="0,28,0,0">
                    <TextBlock Text="{Binding RemainingTimeDisplay}" FontSize="40" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"
                               Visibility="{Binding CanContinue, Converter={StaticResource InverseBoolToVis}}" />
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Reading_TimeRemainingHint]}"
                               Style="{StaticResource BodyText}" TextAlignment="Center" Margin="0,4,0,20"
                               Visibility="{Binding CanContinue, Converter={StaticResource InverseBoolToVis}}" />

                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Reading_Continue]}"
                            Style="{StaticResource RoundedButton}" FontSize="22" Padding="34,14"
                            HorizontalAlignment="Center"
                            IsEnabled="{Binding CanContinue}"
                            Command="{Binding ContinueCommand}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

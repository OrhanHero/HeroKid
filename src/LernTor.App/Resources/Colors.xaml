<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryColor">#6C5CE7</Color>
    <Color x:Key="PrimaryDarkColor">#4834D4</Color>
    <Color x:Key="AccentColor">#FDCB6E</Color>
    <Color x:Key="SuccessColor">#00B894</Color>
    <Color x:Key="ErrorColor">#E17055</Color>
    <Color x:Key="BackgroundColor">#F5F6FA</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="TextPrimaryColor">#2D3436</Color>
    <Color x:Key="TextSecondaryColor">#636E72</Color>

    <Color x:Key="MathColor">#0984E3</Color>
    <Color x:Key="GermanColor">#6C5CE7</Color>
    <Color x:Key="TurkishColor">#E84393</Color>
    <Color x:Key="ScienceColor">#00B894</Color>
    <Color x:Key="NewsColor">#F39C12</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />

    <SolidColorBrush x:Key="MathBrush" Color="{StaticResource MathColor}" />
    <SolidColorBrush x:Key="GermanBrush" Color="{StaticResource GermanColor}" />
    <SolidColorBrush x:Key="TurkishBrush" Color="{StaticResource TurkishColor}" />
    <SolidColorBrush x:Key="ScienceBrush" Color="{StaticResource ScienceColor}" />
    <SolidColorBrush x:Key="NewsBrush" Color="{StaticResource NewsColor}" />

    <!-- Kachel-Palette für die Profil-Auswahl: sanfte Pastell-Hintergründe, die zur Hauptpalette
         passen und die farbige Duolingo-artige Dashboard-Optik geben, ohne unruhig zu wirken. -->
    <Color x:Key="TileLavenderColor">#EDEAFB</Color>
    <Color x:Key="TileSandColor">#FEF3DC</Color>
    <Color x:Key="TileMintColor">#DFF7F0</Color>
    <Color x:Key="TileRoseColor">#FDEAF2</Color>

    <SolidColorBrush x:Key="TileLavenderBrush" Color="{StaticResource TileLavenderColor}" />
    <SolidColorBrush x:Key="TileSandBrush" Color="{StaticResource TileSandColor}" />
    <SolidColorBrush x:Key="TileMintBrush" Color="{StaticResource TileMintColor}" />
    <SolidColorBrush x:Key="TileRoseBrush" Color="{StaticResource TileRoseColor}" />

    <!-- Dezenter Hintergrundring des Fortschrittsrings auf den Profil-Kacheln. -->
    <SolidColorBrush x:Key="ProgressTrackBrush" Color="#E4E6F0" />

</ResourceDictionary>

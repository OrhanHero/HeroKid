<Application x:Class="LernTor.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LernTor.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
            <conv:InverseBooleanConverter x:Key="InverseBool" />
            <conv:NullToVisibilityConverter x:Key="NullToVis" />
            <conv:EmptyStringToVisibilityConverter x:Key="EmptyStringToVis" />
            <conv:SubjectToBrushConverter x:Key="SubjectToBrush" />
            <conv:SubjectToTitleConverter x:Key="SubjectToTitle" />
            <conv:ProfileToSubtitleConverter x:Key="ProfileToSubtitle" />
            <conv:FormatWithArgConverter x:Key="FormatWithArg" />
            <conv:EqualsToSelectedTagConverter x:Key="EqualsToSelectedTag" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
